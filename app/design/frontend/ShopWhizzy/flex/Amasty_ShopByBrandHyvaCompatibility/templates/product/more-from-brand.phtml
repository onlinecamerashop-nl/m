                                (getSlider().scrollWidth / (products.length + pageFillers)) * (active + pageSize);
                                active += pageSize">
                            <?= $themeIcons->renderHtml('arrow-right', 'w-11 h-11 p-1.5 lg:p-3', 20, 20, ["aria-hidden" => "true"]) ?>
                        </button>
                    </div>
                </template>
            </div>
        </div>
    </template>
