                        <button aria-label="<?= $escaper->escapeHtmlAttr(__('Previous')) ?>"
                            class="bg-white shadow-whizzy-header w-11 -mt-16 -ml-2 lg:-ml-4 text-black rounded outline-none focus:outline-none absolute top-1/2 left-0 -translate-y-1/2 z-10 opacity-100 cursor-pointer"
                            :class="{ 'invisible' : active === 0 }" @click="getSlider().scrollLeft =
                                (getSlider().scrollWidth / (products.length + pageFillers)) * (active - pageSize);
