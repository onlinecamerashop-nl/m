{ ?>
    <section class="mt-10 relative">
        <div
            class="absolute w-full h-full blur-lg opacity-40 rounded-lg bg-gradient-to-br from-whizzy-primary-lighter via-whizzy-primary to-whizzy-primary-lighter animate-tilt">
