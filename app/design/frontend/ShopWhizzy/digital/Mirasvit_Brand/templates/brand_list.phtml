?>
<?php $collection = $block->getBrandsByLetters(); ?>

<h1 class="sr-only"><?= __('Brands') ?></h1>
<div class="mst-brand__brand-list" x-data="{active: ''}">

    <div class="toolbar flex flex-wrap justify-between text-center gap-6 mb-8">
        <a href="#"
            class="block py-1.5 px-4 text-sm font-semibold no-underline cursor-pointer uppercase bg-whizzy-primary-lighter text-whizzy-body rounded-md hover:bg-whizzy-primary hover:text-white"
            :class="{'_active cursor-default bg-whizzy-primary text-white': (active == ''), 'cursor-pointer bg-whizzy-primary-lighter text-whizzy-body': (active != '')}"
