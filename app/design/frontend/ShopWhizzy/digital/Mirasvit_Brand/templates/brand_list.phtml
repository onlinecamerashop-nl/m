            <ul class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 xl:grid-cols-8 gap-8 list-none p-0">
                <?php foreach ($brands as $brand): ?>
                    <li class="text-center group">
                        <a href="<?= $brand->getUrl() ?>"
                            class="block text-primary hover:text-whizzy-primary transition-colors duration-200">

                            <div class="mx-auto mb-4 max-w-40 max-h-40 bg-gray-100 rounded-xl overflow-hidden border border-gray-200 shadow-sm aspect-square
                            flex items-center justify-center hover:shadow-md transition-shadow p-2">
