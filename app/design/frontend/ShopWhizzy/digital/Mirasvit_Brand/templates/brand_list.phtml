                    data-letter="<?= $letter ?>" @click.prevent="active = '<?= $letter ?>'">
                    <?= $letter ?>
                </a>
            <?php endforeach; ?>
        </div>
    </div>

    <?php foreach ($collection as $letter => $brands): ?>
        <div class="letter-row border-b border-whizzy-separator last:border-b-0 mt-6 pb-6 js-brand-row"
