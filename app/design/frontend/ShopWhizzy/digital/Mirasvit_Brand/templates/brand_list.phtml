                                    <img src="<?= $block->escapeUrl($brand->getImage()) ?>"
                                        alt="<?= $block->escapeHtmlAttr(__('Logo of %1', $brand->getLabel())) ?>"
                                        class="max-h-32 max-w-full object-contain" loading="lazy">
                                <?php else: ?>
                                    <svg class="w-16 h-16 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                            d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                    </svg>
                                <?php endif; ?>
                            </div>

                            <div class="text-sm font-medium text-whizzy-heading line-clamp-2 leading-tight 
                            group-hover:text-whizzy-primary transition">
                                <?= $block->escapeHtml($brand->getLabel()) ?>
                            </div>
                        </a>
                    </li>
                <?php endforeach; ?>
            </ul>
        </div>
    <?php endforeach; ?>
</div>