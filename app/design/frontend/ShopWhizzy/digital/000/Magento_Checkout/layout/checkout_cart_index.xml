<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" layout="1column"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>

        <move element="checkout.cart.methods.onepage.bottom.php-cart" destination="cart.summary" after="-"/>
        <referenceBlock name="checkout.cart.shipping" remove="true"/>
        <referenceBlock name="page.main.title" remove="true" />
        
        <referenceBlock name="checkout.cart.container">
            <block class="Magento\Cms\Block\Block" name="checkout.cart.cms.block" after="cart.discount" >
                <arguments>
                    <argument name="block_id" xsi:type="string">basket_page_block</argument>
                </arguments>
            </block>
        </referenceBlock>
    </body>
</page>
