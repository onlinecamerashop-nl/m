<?php
/** @var \Mirasvit\Search\Block\Result $block */
/** @var \Magento\Framework\Escaper $escaper */

$indexes = $block->getIndexes();
$tabsThreshold = $block->getTabsThreshold();
$lessThanMinIndexes = [];
$tabsCnt = 0;
$totalCnt = 0;
$currentHtml = $block->getCurrentContent();
$currentHtml = $block->getCurrentIndexSize() == 0 ? '' : $currentHtml;
$productIndex = false;
?>
<ul
    class="mst-search__result-tabs flex flex-nowrap md:flex-wrap p-1 gap-3 lg:gap-x-6 lg:gap-y-3 overflow-x-auto md:overflow-hidden snap-proximity snap-x">
    <?php foreach ($indexes as $index):
        if ($index->getIdentifier() == 'catalogsearch_fulltext')
        {
            $productIndex = $index;
        }

        $collection = $block->getSearchCollection($index);
        $size = $collection->getSize();
        $totalCnt += $size;

        \Mirasvit\Search\Service\DebugService::log($index->getIdentifier(), 'index_identifier');

        if ($size == 0)
        {
            continue;
        }

        if ($size < $tabsThreshold && $index->getIdentifier() != 'catalogsearch_fulltext')
        {
            $lessThanMinIndexes[] = $index;
            continue;
        }

        if (empty($currentHtml))
        {
            $currentHtml = $block->getContentBlock($index)->toHtml();
        }

        $tabsCnt++;
        if ($index->getTitle() == $block->getCurrentIndex()->getTitle()
        && $index->getStoreId() == $block->getCurrentIndex()->getStoreId()): ?>
            <li>
                <a class="active block px-6 py-3 rounded-full text-black uppercase text-sm font-medium whitespace-nowrap ring-4 ring-transparent bg-whizzy-beigehv ring-whizzy-beigebdhv"
                    href="#">
                    <?= __($index->getTitle()) ?>
                </a>
            </li>
        <?php else: ?>
            <li>
                <a class="block px-6 py-3 rounded-full bg-white text-black uppercase text-sm font-medium whitespace-nowrap ring-4 ring-transparent hover:bg-whizzy-beigehv hover:ring-whizzy-beigebdhv"
                    href="<?= $block->getIndexUrl($index) ?>">
                    <?= __($index->getTitle()) ?> (<?= $size ?>)
                </a>
            </li>
        <?php endif ?>
    <?php endforeach ?>
</ul>

<?php if ($block->getCurrentIndex()->getIdentifier() == 'catalogsearch_fulltext' && $block->getCurrentIndexSize() > 0): ?>
    <?php if (!empty($lessThanMinIndexes) && $block->getSearchCollection($block->getCurrentIndex())->getCurPage() == 1): ?>
        <div>
            <?php foreach ($lessThanMinIndexes as $index): ?>
                <div class="mst-search__result-index">
                    <div class="mst-search__result-index-title">
                        <?= __($index->getTitle()) ?>
                    </div>

                    <?= $block->getContentBlock($index)->toHtml() ?>
                </div>
            <?php endforeach ?>
        </div>
    <?php endif ?>

    <?php if ($block->getCurrentIndexSize() > 0 || $totalCnt == 0): ?>
        <?= $currentHtml ?>
    <?php endif ?>
<?php else: ?>
    <?= $currentHtml ?>
<?php endif ?>

<?php if ($totalCnt == 0): ?>
    <?= $block->getContentBlock($productIndex)->toHtml(); ?>
    <?= $block->getLayout()->getBlock("mst.search.no_results")->toHtml(); ?>
<?php endif ?>

<?php if ($block->getCurrentIndexSize() == 0 && $tabsCnt > 1): ?>
    <div class="message notice">
        <div><?= __('Please select other tab to see more results') ?></div>
    </div>
<?php endif ?>

<?php if ($block->isHighlightingEnabled()): ?>
    <script>
        function highlightMatch(element, query, cssClass) {
            let arQuery = query.split(' ');
            let arSpecialChars = [
                { 'key': 'a', 'value': '(à|â|ą|a)' },
                { 'key': 'c', 'value': '(ç|č|c)' },
                { 'key': 'e', 'value': '(è|é|ė|ê|ë|ę|e)' },
                { 'key': 'i', 'value': '(î|ï|į|i)' },
                { 'key': 'o', 'value': '(ô|o)' },
                { 'key': 's', 'value': '(š|s)' },
                { 'key': 'u', 'value': '(ù|ü|û|ū|ų|u)' }
            ];

            if (!document.querySelectorAll(element).length) {
                return;
            }

            document.querySelectorAll(element).forEach(function (item, index) {
                let html = item.innerHTML;

                arQuery.forEach(function (word, key) {
                    word = word.trim();

                    if (word) {
                        word = word.replace(/[\-\[\]{}()*+?.,\\\^$|#\s]/g, '\\$&');
                        arSpecialChars.forEach(function (match, idx) {
                            word = word.replace(new RegExp(match.key, 'g'), match.value);
                        });

                        if ("span".indexOf(word.toLowerCase()) === -1) {
                            html = html.replace(new RegExp('(' + word + '(?![^<>]*>))', 'ig'), function ($1, match) {
                                return '<span class="' + cssClass + '">' + match + '</span>';
                            });
                        }
                    }
                });
                item.innerHTML = html;
            });
        }

        let searchQuery = '<?= $escaper->escapeUrl($block->getRequest()->getParam('q')) ?>';

        highlightMatch(
            '.search.results .product-item-link, .mst-search__index a, .mst-search__index .mst-search__index-content',
            searchQuery,
            'bg-secondary'
        );
    </script>
<?php endif; ?>