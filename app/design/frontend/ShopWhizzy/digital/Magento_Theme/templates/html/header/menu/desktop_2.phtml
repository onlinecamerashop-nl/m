            <?php $linkurl = ($item['url'] === '#') ? null : $escaper->escapeUrl($block->getBaseUrl() . $item['url']); ?>
            <?php if ($item['block']): ?>
                <?php $cmsDropdownBlockHtml = $this->getLayout()->createBlock(CmsBlock::class)->setIdentifier($item['block'])->toHtml(); ?>
                <li class="level-0" x-data="{
                        open: false,
                        canHover(func) {
                            const isHoverableDevice = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
                            if (!isHoverableDevice) return;
                            func();
                        }
                    }" @click.outside="open = false" <?php if ($canOpenOnHover): ?>
                        @mouseenter="canHover(() => { open = true })" @mouseleave="canHover(() => { open = false })" <?php endif ?>
                    @keydown.escape="open = false" <?= ($linkurl) ? "onclick=\"location.href='$linkurl';\"" : '' ?>>
                    <?php $menuId = 'desktop-menu-after-' . $i ?>
                    <button type="button"
                        class="level-0 group w-full flex justify-between items-center gap-1 py-3 font-medium transition top-menu-item has-sub aria-[current=page]:underline data-[has-current]:underline hover:underline underline-offset-4 <?= $menu_text_color . ' ' . $menu_text_color_hover ?>"
                        @click="open = !open" aria-expanded="false" :aria-expanded="open"
                        aria-controls="<?= $escaper->escapeHtml($menuId) ?>">
                        <?php if ($item['icon']): ?>
                            <?= $themeIcons->renderHtml($item['icon'], "flex self-center transition $menu_text_color group-aria-expanded:text-inherit", 20, 20, ['aria-hidden' => 'true']) ?>
                        <?php endif; ?>
                        <span class="relative"><?= $escaper->escapeHtml($item['title']) ?></span>
                        <?= $themeIcons->renderHtml('arrow-down', "flex self-center transition group-aria-expanded:rotate-180 $menu_text_color group-aria-expanded:text-inherit", 16, 16, ['aria-hidden' => 'true']) ?>
                    </button>
                    <div id="<?= $escaper->escapeHtml($menuId) ?>"
                        class="z-40 absolute top-18 bg-white overflow-auto shadow-whizzy-submenu p-8 overflow-hidden <?= ($item['width'] === 'fullwidth') ? 'left-0 w-full' : 'rounded-lg min-w-80'; ?> <?= $header_layout === 'header_3' ? 'rounded-b-lg' : '' ?>"
                        x-show="open === true" x-transition x-cloak>
                        <?php if ($item['width'] === 'fullwidth'): ?>
                            <div class="container">
                            <?php endif; ?>
                            <div id="$menuId" class="text-whizzy-body">
                                <?= /** @noEscape */ $cmsDropdownBlockHtml ?>
                            </div>
                            <?php if ($item['width'] === 'fullwidth'): ?>
                            </div>
                        <?php endif; ?>
                    </div>
                </li>
            <?php else: ?>
                <li>
                    <?php if ($linkurl): ?>
                        <a href="<?= $escaper->escapeUrl($linkurl) ?>" title="<?= $escaper->escapeHtmlAttr($item['title']) ?>"
                            class="level-0 group w-full flex justify-between items-center gap-1 py-3 font-medium transition aria-[current=page]:underline data-[has-current]:underline hover:underline underline-offset-4 <?= $menu_text_color . ' ' . $menu_text_color_hover ?>">
                            <?php if ($item['icon']): ?>
                                <?= $themeIcons->renderHtml($item['icon'], "flex self-center transition $menu_text_color group-aria-expanded:text-inherit", 20, 20, ['aria-hidden' => 'true']) ?>
                            <?php endif; ?>
                            <span class="relative"><?= $escaper->escapeHtml($item['title']) ?></span>
                        </a>
                    <?php else: ?>
                        <span
                            class="level-0 group w-full flex justify-between items-center gap-1 py-3 font-medium transition aria-[current=page]:underline data-[has-current]:underline hover:underline underline-offset-4 cursor-pointer <?= $menu_text_color . ' ' . $menu_text_color_hover ?>">
                            <?php if ($item['icon']): ?>
                                <?= $themeIcons->renderHtml($item['icon'], "flex self-center transition $menu_text_color group-aria-expanded:text-inherit", 20, 20, ['aria-hidden' => 'true']) ?>
                            <?php endif; ?>
                            <span class="relative"><?= $escaper->escapeHtml($item['title']) ?></span>
                        </span>
                    <?php endif; ?>
                </li>
            <?php endif; ?>
            <?php $i++; ?>
        <?php endforeach; ?>
    </ul>
</nav>
<script>
    function initMenuDesktop() {
        return {
            open: false,
            maxLevel: parseInt(this.$root.dataset.maxLevel),
            toggle() {
                this.open = !this.open;
            },
            close() {
                this.open = false;
            },
            canHover(func) {
                const isHoverableDevice = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
                if (!isHoverableDevice) return;
                func();
            },
            setActiveMenu() {
                const maxLevel = this.$root.dataset.maxLevel;
                Array.from(this.$root.querySelectorAll('a'))
                    .filter(link => link.href === window.location.href.split('?')[0])
                    .forEach(item => {
                        item.setAttribute('aria-current', 'page');

                        for (let level = 0; level < maxLevel; level++) {
                            const closestMenu = item.closest(`.level-${level}`);

                            if (closestMenu) {
                                const button = closestMenu.querySelector('button');
                                if (button) {
                                    button.setAttribute('data-has-current', '');
                                }
                            }
                        }
                    }
                    );
            }
        }
    }

    function initSubMenuDesktopItem() {
        return {
            open: false,
            toggle() {
                this.open = !this.open;
                this.$nextTick(() => {
                    this.$refs.childmenuViewAll.focus();
                    this.$refs.childmenuWrapper.scrollIntoView({
                        behavior: 'smooth',
                        block: 'nearest',
                        inline: 'end'
                    });
                });
            },
            close() {
                this.open = false;
                this.$refs.childmenuToggle.focus();
            },
        }
    }

    window.addEventListener('alpine:init', () => {
        Alpine.data('initMenuDesktop', initMenuDesktop);
        Alpine.data('initSubMenuDesktopItem', initSubMenuDesktopItem);
    }, { once: true })
</script>
<?php $hyvaCsp->registerInlineScript() ?>