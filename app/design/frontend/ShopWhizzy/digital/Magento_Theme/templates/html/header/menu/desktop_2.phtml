                <span class="relative"><?= $escaper->escapeHtml($menu_shop_wrap_text) ?></span>
                <?= $themeIcons->renderHtml('arrow-down', "flex self-center transition group-aria-expanded:rotate-180 $menu_text_color group-aria-expanded:text-inherit", 16, 16, ['aria-hidden' => 'true']) ?>
            </button>
            <div id="desktop-menu-panel"
                class="z-40 absolute top-18 left-0 bg-white overflow-auto shadow-whizzy-submenu w-full p-8 overflow-hidden <?= !empty($cmsBlockHtml) ? "grid grid-cols-[minmax(0px,1fr)_theme('spacing.72')]" : '' ?>"
                x-show="open" x-transition x-cloak>
                <div class="container relative overflow-auto">
