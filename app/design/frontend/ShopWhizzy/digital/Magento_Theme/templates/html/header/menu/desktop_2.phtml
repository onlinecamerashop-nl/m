$menu_shop_wrap_text = $whizzyHelper->getConfigValue('header/menu_shop_wrap_text') ?: __('Shop');

$sale_link = (($whizzyHelper->getConfigValue('header/sale_link')) ? $whizzyHelper->getConfigValue('header/sale_link') : 'sale');
$menu_background_color = (($menu_background_color_value = $whizzyHelper->getConfigValue('header/menu_background_color')) ? 'bg-[' . $menu_background_color_value . ']' : 'bg-white');
$menu_text_color = (($menu_text_color_value = $whizzyHelper->getConfigValue('header/menu_text_color')) ? 'text-[' . $menu_text_color_value . ']' : 'text-whizzy-body');

$hover_classes = "aria-expanded:text-black";
$menu_text_color_hover = (($menu_text_color_hover_value = $whizzyHelper->getConfigValue('header/menu_text_color_hover')) ? 'aria-expanded:text-[' . $menu_text_color_hover_value . '] hover:text-[' . $menu_text_color_hover_value . ']' : 'hover:text-whizzy-graylighter');
$show_sale_link = $whizzyHelper->getConfigValue('header/show_sale_link');

$menu_show_home = $whizzyHelper->getConfigValue('header/menu_show_home');
$menu_items_after = (($whizzyHelper->getConfigValue('header/menu_items_after')) ?: '');
$menu_items_after_decoded = (json_decode($menu_items_after, true) ?: []);
?>
<nav class="z-20 navigation hidden lg:flex items-center <?= $header_layout ?>"
    aria-label="<?= $escaper->escapeHtmlAttr(__('Main menu')) ?>" data-max-level="<?= $maxLevel ?>"
    x-data="initMenuDesktop" x-ref="nav-desktop" @load.window="setActiveMenu">
    <ul class="flex flex-wrap gap-x-6 items-center py-3">

        <?php if ($menu_show_home): ?>
            <li class="level-0">
                <a href="<?= $escaper->escapeUrl($block->getBaseUrl()) ?>"
                    class="level-0 group w-full flex justify-between items-center gap-1 p-2 font-medium transition top-menu-item aria-[current=page]:underline data-[has-current]:underline hover:underline underline-offset-4 <?= $menu_text_color . ' ' . $menu_text_color_hover ?>">
                    <?= $themeIcons->renderHtml('home', "flex self-center transition <?= $menu_text_color . ' ' . $menu_text_color_hover ?>", 28, 28, ['aria-hidden' => 'true']) ?>
                    <span class="relative sr-only"><?= $escaper->escapeHtml(__('Home')) ?></span>
                </a>
            </li>
        <?php endif; ?>

        <li @click.outside="close" @keydown.escape.stop="close" <?php if ($canOpenOnHover): ?>
                @mouseenter="canHover(() => { open = true })" @mouseleave="canHover(() => { open = false })" <?php endif ?>>
            <button type="button"
                class="group w-full flex justify-between items-center gap-1 py-3 px-6 font-medium transition top-menu-item has-sub aria-[current=page]:underline data-[has-current]:underline hover:underline underline-offset-4 bg-white rounded-lg hover:rounded-none	hover:rounded-t-lg aria-expanded:rounded-none aria-expanded:rounded-t-lg hover:bg-white aria-expanded:bg-white shadow-whizzy-header <?= $menu_text_color . ' ' . $menu_text_color_hover ?>"
