<page layout="3columns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <update handle="hyva_modal"/>
    <body>

        <referenceBlock name="page.main.title" remove="true"/>
        <referenceBlock name="hero" remove="true"/>
        <referenceBlock name="content-1" remove="true"/>
        <referenceBlock name="slider-1" remove="true"/>
        <referenceBlock name="slider-2" remove="true"/>
        <referenceBlock name="slider-3" remove="true"/>
        
		<referenceContainer name="content">
			<container name="home.cms" htmlClass="w-full" htmlTag="div" before="-">
				<block class="Magento\Framework\View\Element\Template" name="home.cms.content" template="Magento_Theme::html/pages/home.phtml" />
			</container>
		</referenceContainer>

        <referenceBlock name="home.cms.content">
            <action method="setTemplate">
				<argument name="template" xsi:type="helper" helper="ShopWhizzy\DigitalTheme\Helper\UpdaterTemplate::setHomeLayout"/>
			</action>
        </referenceBlock>

    </body>
</page>