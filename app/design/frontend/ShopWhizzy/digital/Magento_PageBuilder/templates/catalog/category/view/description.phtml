<?php
// phpcs:disable Magento2.Templates.ThisInTemplate.FoundHelper

/**
 * Category view template
 *
 * @var $block \Magento\Catalog\Block\Category\View
 */
?>
<?php if ($description = $block->getCurrentCategory()->getDescription()): ?>
    <?php
    $descriptionHtml = $this->helper(Magento\Catalog\Helper\Output::class)->categoryAttribute(
        $block->getCurrentCategory(),
        $description,
        'description'
    );
    ?>
    <div class="category-description my-6" x-data="{ isExpanded: window.innerWidth >= 1024 }">
        <div class="relative overflow-hidden transition-all duration-500 ease-in-out"
            :style="isExpanded ? 'max-height: none' : 'max-height: 5rem'">
            <?php if (stripos($description, 'data-appearance') === false): ?>
                <div data-content-type="row" data-appearance="contained" data-element="main">
                    <div data-enable-parallax="0" data-parallax-speed="0.5" data-background-images="{}" data-element="inner"
                        style="justify-content: flex-start; display: flex; flex-direction: column;
                         background-position: left top; background-size: cover; background-repeat: no-repeat;
                         background-attachment: scroll; border-style: none; border-width: 1px; border-radius: 0px;
                         margin: 0px 0px 10px; padding: 10px;">
                        <div data-content-type="html" data-appearance="default" data-element="main"
                            style="border-style: none; border-width: 1px; border-radius: 0px; margin: 0px; padding: 0px;">
                            <?= /* @noEscape */ $descriptionHtml; ?>
                        </div>
                    </div>
                </div>
            <?php else: ?>
                <?= /* @noEscape */ $descriptionHtml; ?>
            <?php endif; ?>

            <div class="absolute bottom-0 left-0 right-0 h-12 bg-gradient-to-t from-white to-transparent pointer-events-none lg:hidden"
                :class="{ 'hidden': isExpanded }"></div>
        </div>

        <div class="mt-2 lg:hidden">
            <button @click="isExpanded = !isExpanded"
                class="text-sm text-whizzy-primary hover:text-whizzy-primary-darker transition-colors duration-200"
                x-text="isExpanded ? '<?= __('Show Less') ?>' : '<?= __('View More') ?>'"></button>
        </div>

    </div>

    <script>
        document.addEventListener('alpine:init', () => {
            Alpine.data('categoryDesc', () => ({
                isExpanded: window.innerWidth >= 1024,
                init() {
                    window.addEventListener('resize', () => {
                        this.isExpanded = window.innerWidth >= 1024;
                    });
                }
            }));
        });
    </script>

<?php endif; ?>