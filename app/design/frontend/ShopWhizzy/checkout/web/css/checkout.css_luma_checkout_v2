    max-width: max-content;
    margin: 0 auto 20px !important;
    padding: 40px;
    background: #E8F1F3;
    -webkit-border-radius: 12px;
    -moz-border-radius: 12px;
    border-radius: 12px;
    border: 1px solid rgb(230, 232, 233);
    box-shadow: 0 0 #0000, 0 0 #0000, 0 1px 2px 0 rgb(0 0 0 / 0.05);
}

.fieldset.payment.ccard select,
.fieldset.payment.ccard input {
    background: #fff;
}

.checkout-payment-method .ccard .captcha .input-text, .checkout-payment-method .ccard .number .input-text {
    letter-spacing: 1px;
}

.checkout-payment-method .ccard .cvv .input-text {
    width: 140px;
}

.checkout-payment-method .credit-card-types img {
    -webkit-border-radius: 3px;
    -moz-border-radius: 3px;
    border-radius: 3px;
}

/* shipper_hq */
.shq-method-carrier-logo {
    padding-right: 5px;
    padding-bottom: 0;
}

.shq-method-carrier-logo img {
    max-width: 30px;
    width: 100%;
    vertical-align: middle;
    box-shadow: 0px 1px 3px 0px rgba(0, 0, 0, 0.22);
    background: #fff;
    border-radius: 3px;
    margin-right: 5px;
}

.table-checkout-shipping-method tbody tr td.col-carrier {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
}

/* amasty_storepickup */
.ampickup-store-container .ampickup-field select, .ampickup-store-container .ampickup-field input {
    height: 44px;
    padding: 0 12px;
}

.ampickup-details-container.shipping-address-details {
    max-width: max-content;
    margin: 0 auto 20px;
    padding: 40px;
    background: #E8F1F3;
    -webkit-border-radius: 12px;
    -moz-border-radius: 12px;
    border-radius: 12px;
    border: 1px solid rgb(230, 232, 233);
    box-shadow: 0 0 #0000, 0 0 #0000, 0 1px 2px 0 rgb(0 0 0 / 0.05);
}

.amlocator-info-popup .amlocator-image {
    width: 100%;
}

.amlocator-info-popup .amlocator-image img {
    -webkit-border-radius: 8px;
    -moz-border-radius: 8px;
    border-radius: 8px;
}

@media (min-width: 768px), print {
    .opc-wrapper .shipping-address-item {
        flex: 1 0 40%;
    }
}

@media (max-width: 767px) {
    .checkout-payment-method .payment-option .payment-option-title {
        padding: 15px 0;
    }

    .checkout-payment-method .payment-option .payment-option-content {
        padding: 0;
    }

    .checkout-cart-index .cart-container .form.form-cart,
    .checkout-cart-index .cart-container .cart-discount {
        width: 100%;
    }

    .opc-sidebar .modal-inner-wrap {
        -webkit-transform: translateX(0);
        transform: translateX(0);
    }

    .modal-custom.opc-sidebar.custom-slide {
        left: auto;
        position: relative;
        visibility: visible;
        opacity: 1;
    }

    .opc-wrapper .form-discount button {
        width: 100% !important;
    }

    body.checkout-index-index .page-header {
        border: 0;
        padding-bottom: 10px;
    }

    .checkout-payment-method .checkout-billing-address .primary .action-update {
        margin: 10px 0;
    }

    .checkout-index-index .opc-wrapper #checkoutSteps,
    .opc-sidebar .modal-inner-wrap {
        padding: 24px;
        margin-bottom: 20px;
    }

    .opc-wrapper .form-login, .opc-wrapper .form-shipping-address, .opc-wrapper .methods-shipping {
        margin: 20px 0 0;
        padding: 0;
        background: transparent;
        border: 0;
    }

    .authentication-wrapper {
        float: left;
        margin-top: -50px;
    }

    .checkout-payment-method .payment-option {
        margin: 0;
    }

    .custom-slide .modal-inner-wrap {
        background: #fff;
        padding: 40px 24px;
    }

    .checkout-go-back-action {
        display: block;
    }

    .opc-progress-bar-item {
        width: 30%;
    }

    .opc-progress-bar-item:first-child,
    .opc-progress-bar-item:last-child {
        width: 20%;
    }

    .opc-progress-bar-item>span {
        width: 100%;
        font-size: 11px;
    }

    .checkout-index-index .modal-popup:not(.agreements-modal):not(.popup-authentication) .modal-inner-wrap {
        -webkit-border-radius: 0;
        -moz-border-radius: 0;
        border-radius: 0;
    }

    .checkout-index-index .opc-wrapper.am-opc-wrapper .shipping-address-item {
        width: 50%;
    }

    .checkout-index-index .modal-popup .modal-footer .action-hide-popup {
        width: 100%;
        margin-top: 12px;
    }

    .navigation, .breadcrumbs, .page-header .header.panel, .header.content, .footer.content, .page-main, .page-wrapper>.widget, .page-wrapper>.page-bottom, .block.category.event, .top-container {
        padding-left: 24px;
        padding-right: 24px;
    }

    .opc-sidebar {
        position: relative;
        top: 0;
    }

}