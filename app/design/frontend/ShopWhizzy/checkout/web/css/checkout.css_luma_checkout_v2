.opc-progress-bar {
    text-align: center;
    display: block;
    font-size: 0;
    margin-bottom: 20px;
}

.opc-progress-bar-item {
    margin: 0 0 10px;
    width: 200px;
    display: inline-block;
    position: relative;
    text-align: center;
    vertical-align: top;
}

.opc-progress-bar-item:first-child,
.opc-progress-bar-item:last-child {
    width: 100px;
    text-align: left;
}

.opc-progress-bar-item:last-child {
    text-align: right;
}

.opc-progress-bar-item:before {
    background: #ddd;
    border: 0;
    top: 19px;
    transition: background 0.3s;
    content: '';
    height: 2px;
    left: 0;
    position: absolute;
    width: 100%;
}

.opc-progress-bar-item:first-child:before {
    border-radius: 6px 0 0 6px;
}

.opc-progress-bar-item:last-child:before {
    border-radius: 0 6px 6px 0;
}

.opc-progress-bar-item>span {
    display: inline-block;
    padding-top: 35px;
    width: 100%;
    word-wrap: break-word;
    color: #ccc;
    font-weight: 400;
    font-size: 14px;
    text-transform: uppercase;
    transition: all 0.3s;
}

.opc-progress-bar-item:first-child>span {
    cursor: pointer;
}

.opc-progress-bar-item:first-child:hover>span {
    color: #000;
}

.opc-progress-bar-item:first-child:hover>span:before {
    background: #000;
}

.opc-progress-bar-item:first-child:hover>span:after {
    color: #000;
}

.opc-progress-bar-item>span:before,
.opc-progress-bar-item>span:after {
    background: #ccc;
    border: 0;
    height: 26px;
    margin-left: -13px;
    transition: all 0.3s;
    width: 26px;
    border-radius: 50px;
    content: '';
    left: 50%;
    position: absolute;
    top: 7px;
}

.opc-progress-bar-item>span:after {
    background: #ffffff;
    height: 22px;
    margin-left: -11px;
    top: 9px;
    width: 22px;
    content: counter(i);
    counter-increment: i;
    color: #aaa;
    font-weight: 700;
    font-size: 14px;
    line-height: 21px;
    text-align: center;
}

.opc-progress-bar-item._complete {
    cursor: pointer;
}

.opc-progress-bar-item._complete:hover:before {
    background: #d7d7d7;
}

.opc-progress-bar-item._complete:hover>span:before {
    background: #000;
}

.opc-progress-bar-item._complete:hover>span:after {
    color: #000;
}

.opc-progress-bar-item._complete>span {
    color: #ccc;
}

.opc-progress-bar-item._complete:hover>span {
    color: #000;
}

.opc-progress-bar-item._complete>span:after {
    font-family: 'luma-icons';
    content: '\e610';
}

.opc-progress-bar-item._active:before {
    background: linear-gradient(to right, #dddddd 10%, #5ea201 40%, #5ea201 60%, #dddddd 90%);
}

.opc-progress-bar-item._active>span {
    color: #5ea201;
    font-weight: 600;
}

.opc-progress-bar-item._active>span:before {
    background: #5ea201;
}

.opc-progress-bar-item._active>span:after {
    color: #5ea201;
    content: '\00D7';
    font-family: 'Inter', sans-serif;
    font-size: 22px;
    line-height: 19px;
    font-weight: 300;
}

.opc-progress-bar-item:first-child>span:before,
.opc-progress-bar-item:first-child>span:after {
    transition: all 0.3s;
    left: 0;
    margin-left: 0;
}

.opc-progress-bar-item:first-child>span:after {
    margin-left: 2px;
}

.opc-progress-bar-item:last-child>span:before,
.opc-progress-bar-item:last-child>span:after {
    transition: all 0.3s;
    right: 0;
    left: auto;
    margin-right: 0;
