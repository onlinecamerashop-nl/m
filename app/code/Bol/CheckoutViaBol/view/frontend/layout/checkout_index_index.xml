<?xml version="1.0" ?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" layout="1column"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <!-- Enable messages block to display error messages from the backend in case we redirect back to the payment page-->
        <!-- Magento disables this block in Magento_Checkout layout checkout_index_index.xml -->
        <referenceContainer name="page.messages" remove="false"/>

        <referenceBlock name="checkout.root">
            <arguments>
                <argument name="jsLayout" xsi:type="array">
                    <item name="components" xsi:type="array">
                        <item name="checkout" xsi:type="array">
                            <item name="children" xsi:type="array">
                                <item name="cvb_button" xsi:type="array">
                                    <item name="component" xsi:type="string">Bol_CheckoutViaBol/js/view/cvb-button</item>
                                    <item name="displayArea" xsi:type="string">progressBar</item>
                                    <item name="config" xsi:type="array">
                                        <item name="template" xsi:type="string">Bol_CheckoutViaBol/cvb-button</item>
                                    </item>
                                </item>
                                <item name="steps" xsi:type="array">
                                    <item name="children" xsi:type="array">
                                        <item name="billing-step" xsi:type="array">
                                            <item name="children" xsi:type="array">
                                                <item name="payment" xsi:type="array">
                                                    <item name="children" xsi:type="array">
                                                        <item name="renders" xsi:type="array">
                                                            <item name="children" xsi:type="array">
                                                                <item name="cvb" xsi:type="array">
                                                                    <item name="component" xsi:type="string">Bol_CheckoutViaBol/js/view/payment/cvb</item>
                                                                    <item name="methods" xsi:type="array">
                                                                        <item name="cvb" xsi:type="array">
                                                                            <item name="isBillingAddressRequired" xsi:type="boolean">true</item>
                                                                        </item>
                                                                    </item>
                                                                </item>
                                                            </item>
                                                        </item>
                                                    </item>
                                                </item>
                                            </item>
                                        </item>
                                    </item>
                                </item>
                            </item>
                        </item>
                    </item>
                </argument>
            </arguments>
        </referenceBlock>
    </body>
</page>
