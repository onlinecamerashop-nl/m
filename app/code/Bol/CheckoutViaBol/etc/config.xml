<?xml version="1.0" ?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Store:etc/config.xsd">
    <default>
        <payment>
            <cvb>
                <model>CvbFacade</model>
                <title>Achteraf betalen via Bol</title>
                <payment_action>initialize</payment_action>
                <active>1</active>
                <order_status>pending_payment</order_status>
                <allowspecific>0</allowspecific>
                <available_in_backend>0</available_in_backend>
                <order_place_redirect_url>/cvb/order/redirect</order_place_redirect_url>
                <is_gateway>1</is_gateway>
                <can_use_checkout>1</can_use_checkout>
                <can_initialize>1</can_initialize>
                <can_refund>1</can_refund>
                <can_refund_partial_per_invoice>1</can_refund_partial_per_invoice>
                <can_use_internal>0</can_use_internal>
                <can_cancel>0</can_cancel>
                <can_authorize>0</can_authorize>
                <can_authorize_vault>0</can_authorize_vault>
                <can_edit>0</can_edit>
                <group>bol</group>
            </cvb>
        </payment>
    </default>
</config>
