<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="bol_cvb_order">
        <column xsi:type="int" name="entity_id" unsigned="true" nullable="false" identity="true" comment="Entity ID"/>
        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>
        <column xsi:type="int" name="order_id" unsigned="true" nullable="false" comment="Magento order id"/>
        <column xsi:type="varchar" name="cvb_order_reference" length="255" comment="Bol order id"/>
        <column xsi:type="varchar" name="cvb_session_id" length="255" comment="Cvb session id"/>
        <column xsi:type="tinyint" name="shipment_event_status" nullable="false" default="0" comment="Shipment event status"/>
        <column xsi:type="smallint" name="shipment_event_tries" nullable="false" default="0" comment="Shipment event tries"/>
        <column xsi:type="datetime" name="try_shipment_event_again_at" on_update="false" nullable="true" comment="Retry shipment event timestamp"/>
        <column xsi:type="tinyint" name="is_fill_in_session" nullable="false" default="0" comment="If cvb fill in was used for this order"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        <constraint xsi:type="foreign"
                    referenceId="BOL_CVB_ORDER_ORDER_ID_SALES_ORDER_ENTITY_ID"
                    table="bol_cvb_order"
                    column="order_id"
                    referenceTable="sales_order"
                    referenceColumn="entity_id"
                    onDelete="CASCADE"
        />
        <index referenceId="BOL_CVB_ORDER_CVB_ORDER_REFERENCE" indexType="btree">
            <column name="cvb_order_reference"/>
        </index>
    </table>
</schema>
