                    <frontend_class>select-image</frontend_class>
                    <source_model>ShopWhizzy\DigitalTheme\Model\Config\Settings\Category\SubcategoriesTop</source_model>
                    <frontend_model>ShopWhizzy\DigitalTheme\Block\Adminhtml\System\Config\Field\SelectImageField</frontend_model>
                </field>

                <field id="subcategories_bottom_layout" translate="label" type="select" sortOrder="100" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>SubCategories Bottom Version</label>
                    <frontend_class>select-image</frontend_class>
                    <source_model>ShopWhizzy\DigitalTheme\Model\Config\Settings\Category\SubcategoriesBottom</source_model>
                    <frontend_model>ShopWhizzy\DigitalTheme\Block\Adminhtml\System\Config\Field\SelectImageField</frontend_model>
                </field>
			</group>

            <group id="contact_us" translate="label" sortOrder="60" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Contact Us</label>

                <field id="map_iframe" translate="label" type="textarea" sortOrder="10" showInWebsite="1" showInStore="1" showInDefault="1">
					<label>Google Maps Iframe</label>
                    <comment>Google Maps iframe</comment>
				</field>
			</group>

            <group id="developer" translate="label" sortOrder="999" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>CSS</label>

                <field id="css" translate="label" type="textarea" sortOrder="10" showInWebsite="1" showInStore="1" showInDefault="1">
					<label>Custom Css</label>
				</field>
			</group>
		</section>
	</system>
