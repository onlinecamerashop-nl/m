<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">mgtwizards_labels_listing.mgtwizards_labels_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <buttons>
            <button name="add">
                <url path="*/*/new"/>
                <class>primary</class>
                <label translate="true">Add New Label</label>
            </button>
        </buttons>
        <spinner>mgtwizards_labels_columns</spinner>
        <deps>
            <dep>mgtwizards_labels_listing.mgtwizards_labels_listing_data_source</dep>
        </deps>
    </settings>
    <dataSource name="mgtwizards_labels_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">label_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>MgtWizards_Labels::labels</aclResource>
        <dataProvider class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider" name="mgtwizards_labels_listing_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>label_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters"/>
        <paging name="listing_paging"/>
    </listingToolbar>
    <columns name="mgtwizards_labels_columns">
        <column name="label_id" sortOrder="10">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <sorting>asc</sorting>
            </settings>
        </column>
        <column name="name" sortOrder="20">
            <settings>
                <filter>text</filter>
                <label translate="true">Name</label>
            </settings>
        </column>
        <column name="is_active" component="Magento_Ui/js/grid/columns/select" sortOrder="30">
            <settings>
                <options class="Magento\Eav\Model\Entity\Attribute\Source\Boolean"/>
                <filter>select</filter>
                <dataType>select</dataType>
                <label translate="true">Active</label>
            </settings>
        </column>
        <column name="sort_order" sortOrder="40">
            <settings>
                <filter>text</filter>
                <label translate="true">Position</label>
            </settings>
        </column>
        <column name="label" sortOrder="50">
            <settings>
                <filter>text</filter>
                <label translate="true">Label</label>
            </settings>
        </column>
        <column name="css_class" sortOrder="60">
            <settings>
                <filter>text</filter>
                <label translate="true">CSS Class</label>
            </settings>
        </column>
        <column name="stop_rules_processing" component="Magento_Ui/js/grid/columns/select" sortOrder="70">
            <settings>
                <options class="Magento\Eav\Model\Entity\Attribute\Source\Boolean"/>
                <filter>select</filter>
                <dataType>select</dataType>
                <label translate="true">Stop</label>
            </settings>
        </column>
        <actionsColumn name="actions" class="MgtWizards\Labels\Ui\Component\Listing\Column\Actions" sortOrder="200">
            <settings>
                <indexField>label_id</indexField>
            </settings>
        </actionsColumn>
    </columns>
</listing>
