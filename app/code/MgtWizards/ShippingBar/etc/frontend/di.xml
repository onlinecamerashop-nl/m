<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <type name="Magento\Customer\CustomerData\SectionPoolInterface">
        <arguments>
            <argument name="sectionSourceMap" xsi:type="array">
                <item name="shipping-bar" xsi:type="string">MgtWizards\ShippingBar\CustomerData\ShippingBar</item>
            </argument>
        </arguments>
    </type>
    <type name="MgtWizards\ShippingBar\Observer\AddHandle">
        <arguments>
            <argument name="excludeActions" xsi:type="array">
                <item name="checkout_index_index" xsi:type="string">checkout_index_index</item>
                <item name="checkout_onepage_success" xsi:type="string">checkout_onepage_success</item>
            </argument>
        </arguments>
    </type>
</config>
